# Local Foundry module install target used by npm run build.
FOUNDRY_MONSTER_CREATOR_PATH=/mnt/c/Users/Jhow/AppData/Local/FoundryVTT/Data/modules/monster-creator

# Fight Club 5e XML source used by npm run generate:fc5-compendia when --xml is omitted.
FC5_XML_PATH=/tmp/Complete_Compendium_2014_2024.xml

# Release/build manifest base URL used by ./build-monster-creator.sh.
MONSTER_CREATOR_BASE_URL=http://127.0.0.1:8000

# Optional Open5E API override injected by ./build-monster-creator.sh.
MONSTER_CREATOR_API_REMOTE_URL=https://api.open5e.com

# Optional version override for ./build-monster-creator.sh.
# MONSTER_CREATOR_VERSION=1.2.3
